{
  "permissions": {
    "allow": [
      "Bash(ls -la /c/saas_optica/src/app/\\(dashboard\\)/dashboard/configuracion/)",
      "WebFetch(domain:saas-optica.vercel.app)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/saas_optica/.claude/hooks/pre-bash.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /c/saas_optica/.claude/hooks/post-bash.sh"
          }
        ]
      }
    ]
  }
}
